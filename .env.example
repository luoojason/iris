# Copy to .env and fill in. Real environment variables override this file.

# --- Transport (pick one) ---
# Discord bot token from https://discord.com/developers/applications
IRIS_DISCORD_TOKEN=
# Telegram bot token from @BotFather (run with: python -m iris telegram)
IRIS_TELEGRAM_TOKEN=

# Optional: defaults for the Discord server-actions MCP tool (threads, history,
# member search). See iris/mcp/discord_server.py and the tools section in the README.
IRIS_DISCORD_HOME_CHANNEL=
IRIS_DISCORD_GUILD_ID=
# The server-actions tools are default-deny: they reach only the home channel /
# configured guild above. To let them touch more, list the extra ids here
# (comma-separated). An empty list means home only, never "any channel/guild".
IRIS_DISCORD_ALLOWED_CHANNELS=
IRIS_DISCORD_ALLOWED_GUILDS=

# Lock the bot to yourself. STRONGLY RECOMMENDED: serving other people from a
# personal Claude subscription violates Anthropic's terms (see COMPLIANCE.md).
# Comma-separated Discord user ids. Leave blank only if you accept that risk.
IRIS_ALLOWED_USER_IDS=

# Optional: only respond in these channel ids (comma-separated). Blank = anywhere.
IRIS_ALLOWED_CHANNEL_IDS=

# Respond to every message in allowed channels, not just @mentions (true/false).
IRIS_RESPOND_WITHOUT_MENTION=false

# Start a thread when you begin a task in a regular channel (the agent creates
# a thread named after the message and works there), so the channel stays a
# clean launcher and each task gets its own space. Threads auto-reply, so the
# conversation continues there without re-@mentioning. (true/false)
IRIS_AUTO_THREAD=false

# --- Brain (the official claude binary) ---
# Path or name of the claude binary. Must be installed and signed in.
IRIS_CLAUDE_BIN=claude
# Model to use. Blank = Claude Code's default.
IRIS_MODEL=claude-sonnet-4-6

# Persona system prompt file (appended to Claude Code's own system prompt).
IRIS_PERSONA_FILE=examples/persona.example.md

# Standing orders: owner-edited rules appended to the system prompt on every
# chat turn (durable behavior like "always metric", distinct from memory
# facts). Re-read each turn, so edits apply with no restart. Keep it under
# 2KB: every byte is re-billed every turn. Blank = off.
IRIS_STANDING_ORDERS_FILE=

# Optional: a folder of SKILL.md skill folders to make available to the agent.
# Iris symlinks them into ~/.claude/skills at startup. See: python -m iris skills
IRIS_SKILLS_DIR=
# Self-improving skills: Iris may PROPOSE a new/revised skill (propose_skill tool,
# or the maintain review). Proposals are staged here and never change her behavior
# until you run `iris skills approve <id>` (review with `iris skills show <id>`).
IRIS_SKILL_PROPOSALS_FILE=iris-skill-proposals.json
# Most pending proposals at once (a runaway-turn guard).
IRIS_SKILL_PROPOSALS_MAX=10

# Transcribe inbound voice notes locally (needs: pip install -e ".[voice]").
# Off by default: the first voice message downloads a whisper model and runs
# CPU inference, which can be slow on a small host. The model loads lazily, so
# this stays zero-idle until someone actually sends audio.
IRIS_VOICE=false
IRIS_VOICE_MODEL=base   # tiny | base | small | medium — larger = slower, more accurate

# --- Tools (optional; off by default) ---
# Out of the box Iris is a plain chat bot with no tools, which works anywhere the
# claude binary is installed. Tools are opt-in.
#
# IMPORTANT: under permission mode "default", any tool NOT listed in
# IRIS_ALLOWED_TOOLS is SILENTLY SKIPPED (the model may even claim it acted). So
# whenever you expose a tool via IRIS_MCP_CONFIG you must also allowlist it here.
#
# To enable the bundled memory tool:
#   1) pip install -e ".[memory]"
#   2) edit examples/mcp.example.json so "command" is the python from THIS
#      environment (run: which python), then set both of these:
#   IRIS_MCP_CONFIG=examples/mcp.example.json
#   IRIS_ALLOWED_TOOLS=mcp__memory__remember,mcp__memory__recall,mcp__memory__forget
IRIS_MCP_CONFIG=
IRIS_ALLOWED_TOOLS=
IRIS_DISALLOWED_TOOLS=

# Connections registry written by `iris mcp` (your own MCP servers). When this
# file has enabled entries it supersedes IRIS_MCP_CONFIG / IRIS_ALLOWED_TOOLS.
IRIS_CONNECTIONS_FILE=iris-connections.json

# Permission mode for tool use: default | acceptEdits | bypassPermissions | plan
# Prefer a tight IRIS_ALLOWED_TOOLS list over bypassPermissions.
IRIS_PERMISSION_MODE=default

# Extra directories to expose as context (CLAUDE.md dirs), comma-separated.
IRIS_ADD_DIRS=

# --- Routing and compaction (optional) ---
# A lighter model for clearly-trivial turns (blank = always use IRIS_MODEL).
IRIS_MODEL_LIGHT=
# Messages at or under this many characters can route to the light model.
IRIS_TRIVIAL_MAX_CHARS=140
# Condense a conversation onto a fresh session at this many context tokens / turns.
IRIS_COMPACT_AT_TOKENS=150000
IRIS_COMPACT_EVERY=60
# Recent turns carried into a compaction summary. The summary runs on a fresh
# session seeded with these (off the conversation lock), so a compaction never
# blocks an incoming message for the length of a model call.
IRIS_COMPACT_SEED_TURNS=16

# --- Observability (optional) ---
# Per-turn chat telemetry as JSON lines (routing reasons, cost, tokens). Opt-in.
IRIS_METRICS_FILE=
# Trace ledger: one structured record per claude -p invocation across every path
# (chat, job, proactive, goal, compaction): model, outcome, error category,
# timings, model turns, tokens, cost. The backbone for telling, over time,
# whether Iris is improving or regressing. Opt-in; blank disables it.
IRIS_TRACE_FILE=
# Also store the prompt, the reply, and the raw error string in each trace record.
# Off by default for privacy; only metadata + an error category are kept otherwise.
IRIS_TRACE_CAPTURE_CONTENT=false

# --- Just-in-time approvals (optional) ---
# Ask before risky tool uses (Approve/Deny buttons in Discord) via Claude Code's
# native --permission-prompt-tool. Off by default. Also wire the iris-approvals
# MCP server into your mcp.json. Fails closed (deny) on timeout or if unreachable.
IRIS_APPROVALS=false
IRIS_APPROVAL_TIMEOUT=300
IRIS_APPROVALS_FILE=iris-approvals.json

# --- Proactive notifications (iris watch) ---
# Channel to ping when a watched command finishes; see README.
IRIS_NOTIFY_CHANNEL=
IRIS_WATCH_MIN_SECONDS=30

# --- Background jobs (off by default; see README "Background jobs") ---
# Master switch. When off, the jobs tools refuse and nothing spawns.
IRIS_JOBS=false
# The grants ceiling: the most a job may be granted beyond subagents.
# Comma list of: shell, files, browser. Blank = jobs get subagents only.
IRIS_JOB_GRANTS=
# The 'browser' grant launches the official Playwright MCP server inside the
# job (needs Node/npx). Browser turns are token-heavy: snapshots and
# screenshots bill like big pastes, so grant it deliberately. The profile dir
# is the agent's own (cookies you gave it), never your real browser profile.
IRIS_BROWSER_MCP_CMD=npx @playwright/mcp@latest --headless
IRIS_BROWSER_PROFILE_DIR=iris-browser-profile
# Playwright tools a browser job may not call. Default denies only in-page code
# execution (arbitrary JS in a logged-in page); file upload is allowed so the
# agent can do what a human does. Set empty to deny none, or add tools to lock
# down. Headless is more bot-detectable: for fewer blocks on real sites, run
# headed under a virtual display, e.g.
#   IRIS_BROWSER_MCP_CMD=xvfb-run -a npx @playwright/mcp@latest
IRIS_BROWSER_DENY_TOOLS=browser_evaluate,browser_run_code_unsafe
# Active (pending+running) jobs past this count are queued, not launched.
IRIS_JOBS_MAX=2
# Auto-prune terminal jobs (done/failed/cancelled) past this many in the
# registry, keeping the most recent. Active jobs are never pruned.
IRIS_JOBS_KEEP=50
# One job is one claude -p turn with this timeout (seconds).
IRIS_JOB_TIMEOUT=1800
# Optional model/persona for job turns (blank = the chat model / no persona).
IRIS_JOB_MODEL=
IRIS_JOB_PERSONA=
# Verification gate: before a finished job reports "done", an independent cheap
# model rules whether the report actually satisfies the instructions. It only
# annotates (the result is always delivered; a failed check flags it), fails open
# if the reviewer is unreachable, and is skipped when the credit guard is parked.
# Off by default. Blank model falls back to IRIS_GOAL_JUDGE_MODEL.
IRIS_JOB_VERIFY=false
IRIS_JOB_VERIFY_MODEL=
# Pause-and-ask: a job that can't proceed without a decision ends a turn with a
# 'QUESTION:' line; the runner pauses it (needs_input) and pings you instead of
# guessing. Answer with resume_job(id, answer=...) and it resumes the same
# session. This caps how many times one job may pause, so it can never loop.
IRIS_JOB_MAX_QUESTIONS=5
# Job registry and the fold-back inbox (notes for the next chat turn).
IRIS_JOBS_FILE=iris-jobs.json
IRIS_INBOX_FILE=iris-inbox.json
# Active-jobs digest: a tier-0 block injected into the system prompt every turn
# listing jobs in flight (and just finished), so any session — chat, proactive,
# or a compaction-seeded one — sees what's already running and won't launch a
# duplicate. Read fresh per turn. 0 disables. recent_secs keeps a just-finished
# job visible briefly so a turn racing right behind it still sees it.
IRIS_JOBS_DIGEST_BYTES=600
IRIS_JOBS_DIGEST_RECENT_SECS=3600

# --- Scheduled jobs (off by default; see README "Scheduled jobs") ---
# The one place the clock may start work, and only work you recorded
# verbatim (iris schedule add). Each firing is a normal background job:
# grants re-clamped, credit-guard parked, monthly-capped, no overlap.
IRIS_SCHEDULED_JOBS=false
IRIS_SCHEDULES_FILE=iris-schedules.json
# Default per-rule monthly fire cap (a rule can set its own with --cap).
IRIS_SCHEDULE_MONTHLY_CAP=62
# Most schedule rules the chat tool (schedule_job) may have recorded at once.
# CLI-authored rules do not count. Job rules only; chat can never put a shell
# command on the clock.
IRIS_SCHEDULES_MAX_MODEL_RULES=10

# --- Autonomous resume (off by default; see README "Autonomous resume") ---
# A background command you launched with run_in_background(autoresume=True) may
# fire ONE follow-up turn on the home channel when it finishes, so a chain
# carries itself forward. Never starts a conversation from nothing; dropped when
# the credit guard parks; capped per UTC day.
IRIS_AUTO_RESUME=false
IRIS_AUTO_RESUME_MAX_PER_DAY=12
# How often the bot drains the resume queue (seconds).
IRIS_RESUME_POLL_SECS=20
IRIS_RESUME_QUEUE_FILE=iris-resume.json
IRIS_RESUME_STATE=iris-resume.state.json

# --- Proactive reviews (off by default; see README "Proactive reviews") ---
# On a cron, Iris reviews her state and either does a small useful thing or
# tidies herself: assist (twice a day, outward) and maintain (every ~3 days,
# inward). Gated on the REAL weekly plan usage so it never crowds out your own
# work: a review runs only while seven-day utilization is under the max, with
# the credit-guard park as a hard backstop. Run from cron:
#   python -m iris proactive-tick assist     (and: maintain)
IRIS_PROACTIVE=false
# Stop self-initiated work once seven-day usage reaches this percent (keeps the
# top headroom for your interactive work on the shared Max account).
IRIS_PROACTIVE_USAGE_MAX=80
IRIS_PROACTIVE_USAGE_CACHE=iris-usage-weekly.json
# The OAuth credentials file the weekly-usage number is read from (re-read each
# cycle; the token rotates). Empty -> ~/.claude/.credentials.json at runtime.
IRIS_PROACTIVE_CREDS=

# --- Goal loop (off by default; see README "Goals") ---
# A standing objective the clock advances one step at a time until it's done or
# needs you. You set a goal in chat; a tick runs one work step per fire, an
# independent cheap-model judge rules done/blocked/continue, and Iris pings the
# thread you set it in. Shares the proactive weekly-usage leash above. Run from
# cron:  python -m iris goal-tick
IRIS_GOALS=false
IRIS_GOALS_FILE=iris-goals.json
# Default per-goal step budget before it stops and asks you (a goal can set its
# own). Bounds spend on a goal that never converges.
IRIS_GOALS_MAX_STEPS=20
# Most simultaneously-active goals the chat tool (set_goal) may record at once.
IRIS_GOALS_MAX_ACTIVE=10
# The independent judge model: cheap and second-opinion, never the worker model.
IRIS_GOAL_JUDGE_MODEL=claude-haiku-4-5
# When the judge rules a goal "done", re-check the actual work with an independent
# read-only verifier before accepting it (unconfirmed -> ask you instead). Fires
# only on a done verdict, so it adds at most one cheap call per completion.
IRIS_GOALS_VERIFY_DONE=true

# --- Workspaces (directories jobs may work in) ---
# The model never names paths: you register directories under short names with
#   iris workspaces add <name> <path>   (also: remove <name>, list)
# and jobs say workspace="<name>". A job's report can hand files back with
# "ARTIFACT: relative/path" lines; at most 5 files / 8 MB total are uploaded
# to the home channel, and anything skipped is named in the report.
IRIS_WORKSPACES_FILE=iris-workspaces.json

# --- Credit guard ---
# Monthly budget in USD-estimate terms (the claude CLI's per-turn cost_usd,
# summed). 0 = off: the ledger still records, but nothing pings, parks, or
# tightens. See `iris usage`.
IRIS_USAGE_BUDGET_USD=0
IRIS_USAGE_FILE=iris-usage.json
# Ping the home channel once per crossed threshold (percent of budget).
IRIS_USAGE_PING_AT=50,80,95
# At tighten% the light-model routing gets more aggressive (cap x factor);
# at park% new background jobs are parked instead of launched.
IRIS_USAGE_TIGHTEN_AT=80
IRIS_USAGE_PARK_AT=95
IRIS_TIGHTEN_FACTOR=3

# --- Event wakes (optional) ---
# Owner-authored rules the reminders tick evaluates cheaply: a file appears
# or vanishes, changes, or a log gains a matching line. A fire pings you and
# folds into the agent's next turn; no model call ever happens on the tick.
# Validate with `iris doctor`. See the README "Event wakes" section.
IRIS_WAKES_FILE=iris-wakes.json
IRIS_WAKES_STATE=iris-wakes.state.json
# Per-fetch timeout (seconds) for url / url_pattern wake kinds (change watcher).
IRIS_WAKE_HTTP_TIMEOUT=15

# --- Webhook wakes (optional; inbound HTTP, off by default) ---
# Lets an external system PUSH a wake: an authorized POST becomes a Discord ping
# plus a fold-back inbox note, never a model call. Run as its own process:
#   python -m iris webhook
# Inbound network surface, so it is tight: bound to localhost by default, and a
# token is MANDATORY (the server refuses to start without one). Widen the bind
# only to a trusted address (e.g. a tailnet IP), never 0.0.0.0 casually. POST to
# http://<bind>:<port>/<name> with header 'X-Iris-Token: <token>' (or ?token=).
IRIS_WEBHOOK=false
IRIS_WEBHOOK_BIND=127.0.0.1
IRIS_WEBHOOK_PORT=8787
IRIS_WEBHOOK_TOKEN=
# Channel for webhook pings; blank uses the home channel.
IRIS_WEBHOOK_CHANNEL=

# --- Quiet heartbeat (optional) ---
# An owner-authored checklist of "should be true" conditions the reminders tick
# checks with no model call: disk_free (free % above a floor), file_fresh (a file
# changed within N seconds — e.g. a backup/cron ran), url_ok (a URL returns 200).
# Silent when healthy; one consolidated ping ONLY when the failing set changes,
# and a recovery note when it clears. See it any time with `iris heartbeat`;
# validate with `iris doctor`. Inert until the file exists.
IRIS_HEARTBEAT_FILE=iris-heartbeat.json
IRIS_HEARTBEAT_STATE=iris-heartbeat.state.json
IRIS_HEARTBEAT_HTTP_TIMEOUT=15

# --- Wiki tools (optional) ---
# Point at an Obsidian-style vault to give the agent wiki_read/wiki_write/
# wiki_append/wiki_list/wiki_search (allowlist mcp__wiki__* too). Blank = off.
IRIS_WIKI_DIR=

# --- YouTube view counts (optional; the channel_views tool) ---
# Reads the channel's public view counts via yt-dlp, no browser. Set the channel
# id to enable it (allowlist mcp__youtube__channel_views; add the youtube MCP
# server). yt-dlp path: a full path is safest (the MCP server has a minimal PATH).
IRIS_YOUTUBE_CHANNEL=
IRIS_YT_DLP_BIN=yt-dlp

# --- Publishing (optional; the publish_video tool) ---
# Posting a video to social accounts is irreversible and public, so it fails
# closed: with IRIS_PUBLISH_DIR unset, nothing is publishable. Set it to the
# directory of finished videos and only files inside it can be published.
IRIS_PUBLISH_DIR=

# --- State ---
IRIS_SESSION_STORE=iris-sessions.json
IRIS_MEMORY_FILE=iris-memory.json
# Byte budget for the pinned-memory digest rendered into the system prompt on
# every turn (tier-0 memory: pinned notes load without a recall call). 0 turns
# it off. Halves automatically while the credit guard is hot.
IRIS_MEMORY_DIGEST_BYTES=2400
IRIS_REMINDERS_FILE=iris-reminders.json
# Most reminders the agent may have pending at once (a runaway-loop guard;
# reminders you create yourself from the CLI do not count).
IRIS_REMINDERS_MAX_PENDING=25
IRIS_TURN_TIMEOUT=300
