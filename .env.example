# Copy to .env and fill in. Real environment variables override this file.

# --- Transport (pick one) ---
# Discord bot token from https://discord.com/developers/applications
IRIS_DISCORD_TOKEN=
# Telegram bot token from @BotFather (run with: python -m iris telegram)
IRIS_TELEGRAM_TOKEN=

# Optional: defaults for the Discord server-actions MCP tool (threads, history,
# member search). See iris/mcp/discord_server.py and the tools section in the README.
IRIS_DISCORD_HOME_CHANNEL=
IRIS_DISCORD_GUILD_ID=

# Lock the bot to yourself. STRONGLY RECOMMENDED: serving other people from a
# personal Claude subscription violates Anthropic's terms (see COMPLIANCE.md).
# Comma-separated Discord user ids. Leave blank only if you accept that risk.
IRIS_ALLOWED_USER_IDS=

# Optional: only respond in these channel ids (comma-separated). Blank = anywhere.
IRIS_ALLOWED_CHANNEL_IDS=

# Respond to every message in allowed channels, not just @mentions (true/false).
IRIS_RESPOND_WITHOUT_MENTION=false

# --- Brain (the official claude binary) ---
# Path or name of the claude binary. Must be installed and signed in.
IRIS_CLAUDE_BIN=claude
# Model to use. Blank = Claude Code's default.
IRIS_MODEL=claude-sonnet-4-6
# Optional: route clearly-trivial turns ("thanks", "lol", short greetings) to a
# lighter, cheaper model to stretch your agent credit. Anything substantive (long
# messages, code, questions that need reasoning, attachments) still uses IRIS_MODEL.
# Leave blank to run every turn on IRIS_MODEL. Set a model id to enable routing.
IRIS_MODEL_LIGHT=

# Persona system prompt file (appended to Claude Code's own system prompt).
IRIS_PERSONA_FILE=examples/persona.example.md

# Optional: a folder of SKILL.md skill folders to make available to the agent.
# Iris symlinks them into ~/.claude/skills at startup. See: python -m iris skills
IRIS_SKILLS_DIR=

# Transcribe inbound voice messages locally and free (needs: pip install -e ".[voice]").
# Off by default: the first voice message downloads a small whisper model and runs
# CPU inference, which can be slow on small hosts. base is a good speed/quality balance;
# tiny is faster, small/medium are more accurate.
IRIS_VOICE=false
IRIS_VOICE_MODEL=base

# Voice replies (text-to-speech): the bundled mcp__tts__speak tool renders a reply
# locally and posts the audio to Discord. It uses, in order: IRIS_TTS_CMD, then
# piper (set IRIS_TTS_VOICE to a voice .onnx), then macOS `say`, then espeak-ng.
# Enable by adding the tts server to your mcp config and allowlisting mcp__tts__speak.
# IRIS_TTS_CMD is a template that reads text on stdin and writes audio to {out}.
IRIS_TTS_CMD=
IRIS_TTS_VOICE=

# --- Tools (optional; off by default) ---
# Out of the box Iris is a plain chat bot with no tools, which works anywhere the
# claude binary is installed. Tools are opt-in.
#
# IRIS_ALLOWED_TOOLS turns ON the MCP tools you expose via IRIS_MCP_CONFIG: under
# permission mode "default" an MCP tool not listed here is silently skipped, so
# allowlist every tool you wire up. Note it is an APPROVAL list, not an exclusive
# boundary: on its own it does not stop the host's built-in tools (Bash, Write,
# WebFetch, ...) from running. Iris closes that gap below.
#
# To enable the bundled memory tool:
#   1) pip install -e ".[memory]"
#   2) edit examples/mcp.example.json so "command" is the python from THIS
#      environment (run: which python), then set both of these:
#   IRIS_MCP_CONFIG=examples/mcp.example.json
#   IRIS_ALLOWED_TOOLS=mcp__memory__remember,mcp__memory__recall,mcp__memory__forget
IRIS_MCP_CONFIG=
IRIS_ALLOWED_TOOLS=
IRIS_DISALLOWED_TOOLS=

# Deny the dangerous built-in tools (Bash, Write, Edit, WebFetch, Task, ...) by
# default, so IRIS_ALLOWED_TOOLS is a real boundary even when your host
# ~/.claude/settings.json pre-approves those tools. Read stays available so
# attachments work. Set false only if you want the agent to have host shell/file
# /web reach. An explicit IRIS_DISALLOWED_TOOLS overrides this default set.
IRIS_RESTRICT_BUILTIN_TOOLS=true
# Keep Claude Code's native auto-memory off so the MCP memory tool is the store
# (otherwise the model may write ~/.claude/projects/<proj>/memory files instead).
IRIS_DISABLE_AUTO_MEMORY=true

# Permission mode for tool use: default | acceptEdits | bypassPermissions | plan
# Prefer a tight IRIS_ALLOWED_TOOLS list over bypassPermissions.
IRIS_PERMISSION_MODE=default

# Extra directories to expose as context (CLAUDE.md dirs), comma-separated.
IRIS_ADD_DIRS=

# Optional: clamp the Discord server-actions tools to specific channels/servers
# (comma-separated ids). The home/guild defaults above are conveniences, not a
# boundary; an agent-supplied id otherwise reaches any channel the bot is in.
IRIS_DISCORD_ALLOWED_CHANNELS=
IRIS_DISCORD_ALLOWED_GUILDS=

# Token-bearing MCP servers (discord, tts, publish) do NOT inherit IRIS_* vars:
# the driver strips them from the claude child for safety. To give such a server
# its secret, put it in that server's own "env" block in your mcp config file.

# --- Publishing (optional: post finished videos to YouTube + Instagram) ---
# See docs/PUBLISHING-SETUP.md for the one-time account setup. Then add the
# publish server to your mcp config and allowlist mcp__publish__publish_video.
# Tokens file (600, never commit it): {yt_client_id, yt_client_secret,
# yt_refresh_token, ig_user_id, ig_access_token}
IRIS_SOCIAL_TOKENS=iris-social.json
# Optional: only allow publishing files inside this directory, so the agent
# cannot post arbitrary files. Blank = no restriction.
IRIS_PUBLISH_DIR=
# Instagram needs a public video URL; host the mp4 on any S3-compatible store.
IRIS_MEDIA_BUCKET=
IRIS_MEDIA_ENDPOINT=
IRIS_MEDIA_PUBLIC_BASE=

# --- State ---
IRIS_SESSION_STORE=iris-sessions.json
IRIS_MEMORY_FILE=iris-memory.json
IRIS_TURN_TIMEOUT=300
# Retries for transient failures (rate limit / overload), with exponential backoff.
IRIS_MAX_RETRIES=2
IRIS_RETRY_BASE_DELAY=2
# Timeouts are retried separately and default to 0: a hung turn reports at once
# instead of blocking for several more full timeouts. Raise only if you want it
# to retry a timed-out turn.
IRIS_TIMEOUT_RETRIES=0

# Auto-compaction: when a turn's context reaches this many tokens, Iris
# summarizes the conversation and carries the summary onto a fresh session, so a
# long chat never outgrows the model's context window (200k). This is the
# accurate trigger; it also catches one tool-heavy turn. 0 disables it.
IRIS_COMPACT_AT_TOKENS=150000
# Backstop trigger: also compact after this many turns, in case token usage is
# ever unavailable. Each compaction is one background summary call. 0 disables.
IRIS_COMPACT_EVERY=60
