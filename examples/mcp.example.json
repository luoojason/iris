{
  "mcpServers": {
    "memory": {
      "command": "python",
      "args": ["-m", "iris.mcp.memory_server"],
      "env": {
        "IRIS_MEMORY_FILE": "iris-memory.json"
      }
    },
    "jobs": {
      "command": "python",
      "args": ["-m", "iris.mcp.jobs_server"],
      "env": {
        "IRIS_JOBS_FILE": "iris-jobs.json"
      }
    },
    "usage": {
      "command": "python",
      "args": ["-m", "iris.mcp.usage_server"],
      "env": {
        "IRIS_METRICS_FILE": "iris-metrics.jsonl",
        "IRIS_MONTHLY_CREDIT": "0"
      }
    },
    "wiki": {
      "command": "python",
      "args": ["-m", "iris.mcp.wiki_server"],
      "env": {
        "IRIS_WIKI_DIR": "/path/to/your/vault"
      }
    }
  }
}
