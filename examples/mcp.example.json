{
  "mcpServers": {
    "memory": {
      "command": "python",
      "args": ["-m", "iris.mcp.memory_server"],
      "env": {
        "IRIS_MEMORY_FILE": "iris-memory.json"
      }
    },
    "reminders": {
      "command": "python",
      "args": ["-m", "iris.mcp.reminders"]
    },
    "jobs": {
      "command": "python",
      "args": ["-m", "iris.mcp.jobs"]
    },
    "usage": {
      "command": "python",
      "args": ["-m", "iris.mcp.usage"]
    },
    "wiki": {
      "command": "python",
      "args": ["-m", "iris.mcp.wiki"]
    }
  }
}
